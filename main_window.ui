  <property name="styleSheet">
   <string notr="true">QMainWindow {
    background-color: #0A192F;
    color: #E0E0E0;
    font-family: 'Helvetica Neue', 'Source Sans Pro';
}
QGroupBox {
    background-color: #112240;
    color: #E0E0E0;
    border: 1px solid #00BFFF;
    border-radius: 5px;
    margin-top: 1em;
    padding-top: 10px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 3px;
    color: #00BFFF;
}
QLabel {
    color: #E0E0E0;
}
QPushButton {
    background-color: #00BFFF;
    color: #0A192F;
    border: none;
    border-radius: 3px;
    padding: 5px 15px;
    font-weight: bold;
}
QPushButton:hover {
    background-color: #FF6F00;
}
QPushButton:disabled {
    background-color: #112240;
    color: #666666;
}
QDoubleSpinBox {
    background-color: #112240;
    color: #E0E0E0;
    border: 1px solid #00BFFF;
    border-radius: 3px;
    padding: 3px;
}
QComboBox {
    background-color: #112240;
    color: #E0E0E0;
    border: 1px solid #00BFFF;
    border-radius: 3px;
    padding: 3px;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
QComboBox::down-arrow {
    image: url(down_arrow.png);
    width: 12px;
    height: 12px;
}
QTextEdit {
    background-color: #112240;
    color: #E0E0E0;
    border: 1px solid #00BFFF;
    border-radius: 3px;
    padding: 5px;
}
QScrollBar:vertical {
    border: none;
    background-color: #112240;
    width: 10px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background-color: #00BFFF;
    border-radius: 5px;
    min-height: 20px;
}
QScrollBar::handle:vertical:hover {
    background-color: #FF6F00;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}
QLineEdit {
    background-color: #112240;
    color: #E0E0E0;
    border: 1px solid #00BFFF;
    border-radius: 3px;
    padding: 3px;
}</string>
